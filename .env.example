# ── 三人行 (sanrenxing) seat configuration ───────────────────────────────────
# Each seat is an OpenAI-compatible chat endpoint. Mix any providers/models that
# speak the OpenAI Chat Completions API. Copy this file to `.env` and fill it in
# (the MCP host or `source .env` must export these into the process env).
#
# Only SEAT*_MODEL is required to enable a seat. base_url/api_key fall back to the
# shared OPENAI_BASE_URL / OPENAI_API_KEY below if a seat doesn't set its own.

# Shared fallback (optional) — used by any seat that omits its own base_url/key.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-REPLACE_ME

# ── Seat 1 · 证据席 (evidence / retrieval lens) ──
SEAT1_NAME=证据席
SEAT1_MODEL=gpt-4o
# SEAT1_BASE_URL=https://api.openai.com/v1
# SEAT1_API_KEY=sk-...
# SEAT1_PERSONA=你是『证据席』，擅长检索证据、整合文献，给出关键依据与机制。

# ── Seat 2 · 批判席 (critique / methodology lens) ──
SEAT2_NAME=批判席
SEAT2_MODEL=deepseek-chat
# SEAT2_BASE_URL=https://api.deepseek.com
# SEAT2_API_KEY=sk-...

# ── Seat 3 · 发散席 (unconventional / divergent lens) ──
SEAT3_NAME=发散席
SEAT3_MODEL=moonshot-v1-32k
# SEAT3_BASE_URL=https://api.moonshot.cn/v1
# SEAT3_API_KEY=sk-...

# ── Curator (writes the possibility map) — defaults to Seat 1 if unset ──
# CURATOR_MODEL=gpt-4o
# CURATOR_BASE_URL=https://api.openai.com/v1
# CURATOR_API_KEY=sk-...

# ── Web demo (web/server.py) ──
SANRENXING_HOST=127.0.0.1
SANRENXING_PORT=8030
SANRENXING_ROUNDS=2
# Optional HTTP Basic Auth for a shared deployment (both required to enable):
# SANRENXING_USER=lab
# SANRENXING_PASS=change-me
